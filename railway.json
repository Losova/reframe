{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install && npm run build",
    "watchPatterns": [
      "/client/**",
      "/server/**",
      "/package.json",
      "/package-lock.json",
      "/railway.json",
      "/nixpacks.toml"
    ]
  },
  "deploy": {
    "startCommand": "npm run start",
    "healthcheckPath": "/api/config",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
