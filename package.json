{
  "name": "reframe",
  "version": "1.0.0",
  "private": true,
  "main": "desktop/main.cjs",
  "engines": {
    "node": ">=20 <25",
    "npm": ">=10"
  },
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n client,server -c cyan,yellow \"npm run dev -w client\" \"npm run dev -w server\"",
    "build": "npm run build -w client",
    "desktop": "npm run build && electron .",
    "dist": "npm run build && electron-builder",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "start": "npm run start -w server",
    "test": "npm run test -w client && npm run test -w server"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "electron": "^35.7.5",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.reframe.review",
    "productName": "Reframe",
    "directories": {
      "output": "release"
    },
    "files": [
      "client/dist/**/*",
      "desktop/**/*",
      "server/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".env.example",
        "to": ".env.example"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "category": "Utility",
      "target": [
        "AppImage"
      ]
    }
  }
}
